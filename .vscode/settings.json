{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "sqltools.connections": [
    {
        "mysqlOptions": {
            "authProtocol": "default",
            "enableSsl": "Disabled"
        },
        "previewLimit": 50,
        "server": "localhost",
        "port": 3306,
        "driver": "MySQL",
        "name": "mysql",
        "database": "blog_app",
        "username": "root"
    }
]
}
